// Copy this file to Secrets.xcconfig (gitignored) and fill in your own
// value to enable Google Drive backup on iOS.
//
// GOOGLE_REVERSED_CLIENT_ID is the iOS OAuth client id from Google Cloud
// Console, reversed (see docs/google-drive-sync-setup.md). Info.plist
// references it as $(GOOGLE_REVERSED_CLIENT_ID). Building without
// Secrets.xcconfig works fine — Drive backup just shows "not configured".
GOOGLE_REVERSED_CLIENT_ID = com.googleusercontent.apps.1234567890-abcdef
